# Application
APP_NAME=DCDeepTech API Gateway
APP_ENV=development

# Security — generate with: openssl rand -hex 32
SECRET_KEY=change_me_to_a_long_random_secret_key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/dcdeeptech

# CORS (comma-separated)
CORS_ORIGINS=https://platform.dcdeeptech.com,http://localhost:5173

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Billing
DEFAULT_CURRENCY=USD
